{
  "name": "routewise",
  "version": "0.1.0",
  "description": "RouteWise: Open-source step-level router for AI agents that plans workflows, selects the right model/tool per step, evaluates outputs, and produces full execution traces",
  "type": "module",
  "bin": {
    "routewise": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "rimraf dist .routewise"
  },
  "keywords": [
    "ai",
    "ai-agents",
    "agentic-ai",
    "llm",
    "llm-router",
    "workflow",
    "workflow-automation",
    "mcp",
    "model-context-protocol",
    "claude-code",
    "cursor",
    "typescript",
    "developer-tools",
    "agent-framework",
    "open-source",
    "ai-orchestration",
    "multi-model",
    "router",
    "model-routing"
  ],
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "cosmiconfig": "^9.0.0",
    "openai": "^4.86.0",
    "pino": "^9.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
